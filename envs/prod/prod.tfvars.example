# =============================================================================
# Prod Environment — Example Variables
#
# cp prod.tfvars.example prod.tfvars
# terraform init -backend-config="bucket=YOUR-TFSTATE-BUCKET"
# terraform plan  -var-file=prod.tfvars
# terraform apply -var-file=prod.tfvars
# =============================================================================

project_id    = "my-gcp-project-prod"
region        = "europe-west1"
environment   = "prod"
naming_prefix = "procwatch"

bucket_location = "EU"
bq_location     = "EU"

dataproc_subnet_cidr = "10.100.0.0/24"

# Pin to a specific release tag in prod
downloader_image_tag     = "v1.0.0"
dataproc_container_image = "europe-west1-docker.pkg.dev/my-gcp-project-prod/spark/procurement-spark:v1.0.0"

# Daily pipeline schedule — 03:00 UTC
schedule_cron = "0 3 * * *"
time_zone     = "Europe/Warsaw"
