# =============================================================================
# Dev Environment — Example Variables
#
# cp dev.tfvars.example dev.tfvars
# terraform init -backend-config="bucket=YOUR-TFSTATE-BUCKET"
# terraform plan  -var-file=dev.tfvars
# terraform apply -var-file=dev.tfvars
# =============================================================================

project_id    = "my-gcp-project-dev"
region        = "europe-west1"
environment   = "dev"
naming_prefix = "procwatch"

bucket_location = "EU"
bq_location     = "EU"

dataproc_subnet_cidr = "10.100.0.0/24"

# Images are NOT managed by Terraform — CI updates them directly after each build:
#   Downloader: gcloud run jobs update bzp-downloader --image=<AR>/procurement-downloader:<SHA> --region=REGION
#   Spark:      gcloud scheduler jobs update http bzp-daily-trigger --location=REGION --message-body='{"argument":"{...container_image:<SHA>...}"}'

# Daily pipeline schedule — 03:00 UTC
schedule_cron = "0 3 * * *"
time_zone     = "Europe/Warsaw"

# GitHub repo allowed to authenticate via Workload Identity Federation (owner/name)
github_repo = "jjkiljanski/procurement-watchdog-lakehouse"

# Earliest date included in CI-triggered backfills (inclusive)
backfill_start_date = "2024-01-01"

# Alerting
billing_account    = "XXXXXX-XXXXXX-XXXXXX"   # gcloud billing projects describe PROJECT_ID --format='value(billingAccountName)'
alert_email        = "your-email@example.com"
monthly_budget_usd = 20
